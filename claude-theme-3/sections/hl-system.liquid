{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-system-section"
    {%- if section.settings.bg_image != blank -%}
      style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');"
    {%- else -%}
      style="background-image: url('https://framerusercontent.com/images/EM5wEPiSExEnHvtRXO7LIAnYb0.png');"
    {%- endif -%}
  >
    <div class="hl-system-inner">

      <div class="hl-section-header-left" style="margin-bottom:30px;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="hl-system-content">

        <div class="hl-system-image">
          {%- if section.settings.system_image != blank -%}
            <img src="{{ section.settings.system_image | image_url: width: 800 }}"
                 alt="{{ section.settings.system_image.alt | default: 'HydroLid System' | escape }}"
                 loading="lazy"
                 width="800"
                 height="900">
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1501554728187-ce583db33af7?w=800&h=900&fit=crop"
                 alt="HydroLid System"
                 loading="lazy"
                 width="800"
                 height="900">
          {%- endif -%}
        </div>

        <div class="hl-system-details">

          {%- if section.settings.quote != blank -%}
            <div class="hl-system-quote">
              <h3>{{ section.settings.quote }}</h3>
            </div>
          {%- endif -%}

          <div class="hl-features-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <div class="hl-feature-item" {{ block.shopify_attributes }}>
                  <div class="hl-feature-icon">
                    {%- case forloop.index -%}
                      {%- when 1 -%}
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- when 2 -%}
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                      {%- when 3 -%}
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                      {%- when 4 -%}
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    {%- endcase -%}
                  </div>
                  <p class="hl-body">{{ block.settings.feature_text }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if section.settings.btn_label != blank -%}
            <div>
              <a href="{{ section.settings.btn_link }}" class="hl-btn hl-btn-accent">{{ section.settings.btn_label }}</a>
            </div>
          {%- endif -%}

        </div>
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "HL - The System",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (optional)"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The System"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not a Lid. A Complete Upgrade System."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "system_image",
      "label": "System Image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / Subheading",
      "default": "HydroLid transforms your bottle into a hands-free hydration system."
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "See the System"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text",
          "default": "Feature description"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "HL - The System",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature_text": "Modular hose system"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Quick-access drinking without removing your pack"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Compatible with insulated bottles"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Built for rugged use"
          }
        }
      ]
    }
  ]
}
{% endschema %}
