{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-origin-section"
    {%- if section.settings.bg_image != blank -%}
      style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');"
    {%- else -%}
      style="background-image: url('https://framerusercontent.com/images/sfIFtdbUjFdrEEIyKTcp7Lcs.png');"
    {%- endif -%}
  >
    <div class="hl-origin-inner">

      <div class="hl-origin-left">
        <div class="hl-section-header-left" style="margin-bottom:30px;">
          {%- if section.settings.eyebrow != blank -%}
            <p class="hl-sub-heading">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>

        <div class="hl-timeline">
          {%- for block in section.blocks -%}
            {%- if block.type == 'timeline_item' -%}
              <div class="hl-timeline-item" {{ block.shopify_attributes }}>
                <div class="hl-timeline-dot"></div>
                <div class="hl-timeline-label">
                  <h6>{{ block.settings.label }}</h6>
                </div>
                <div class="hl-timeline-content">
                  <h4>{{ block.settings.title }}</h4>
                  <p class="hl-body">{{ block.settings.description }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="hl-origin-video">
        {%- if section.settings.video_url != blank -%}
          <video src="{{ section.settings.video_url }}" autoplay loop muted playsinline></video>
        {%- else -%}
          <video src="https://framerusercontent.com/assets/MLWPbW1dUQawJLhhun3dBwpgJak.mp4" autoplay loop muted playsinline></video>
        {%- endif -%}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "HL - Our Origin",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (optional)"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Our Origin"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Born in Fire. Patented for Performance."
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Direct URL to an MP4 video file. Leave blank to use default."
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "The Step"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Timeline Item Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief description of this milestone."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "HL - Our Origin",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Spark",
            "title": "100° Wildfire Conditions",
            "description": "California front lines, fighting heat exhaustion."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Failure",
            "title": "Bladder Water Overheats",
            "description": "Drinking warm plastic water when ice-cold is needed."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Solution",
            "title": "Insulated Bottle Workaround",
            "description": "Combining trusted thermal bottles with hydration tubes."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Build",
            "title": "Field Tested Prototype",
            "description": "Built by hand, tested in operational environments."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Result",
            "title": "Patent Secured",
            "description": "The ultimate hydration system upgrade is born."
          }
        }
      ]
    }
  ]
}
{% endschema %}
