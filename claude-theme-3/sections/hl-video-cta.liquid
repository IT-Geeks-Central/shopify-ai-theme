{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-video-cta">

    <div class="hl-video-cta-bg">
      {%- if section.settings.video_url != blank -%}
        <video src="{{ section.settings.video_url }}" autoplay loop muted playsinline></video>
      {%- else -%}
        <video src="https://framerusercontent.com/assets/MLWPbW1dUQawJLhhun3dBwpgJak.mp4" autoplay loop muted playsinline></video>
      {%- endif -%}
    </div>

    <div class="hl-video-cta-overlay"></div>

    <div class="hl-video-cta-wave">
      {%- if section.settings.wave_image != blank -%}
        <img src="{{ section.settings.wave_image | image_url: width: 2000 }}" alt="" loading="lazy">
      {%- else -%}
        <img src="https://framerusercontent.com/images/W4MXCALFFY2uUB3RJob5dYyk08.png" alt="" loading="lazy">
      {%- endif -%}
    </div>

    <div class="hl-video-cta-content">
      <div class="hl-video-cta-inner">
        <div class="hl-video-cta-text">
          {%- if section.settings.eyebrow != blank -%}
            <p class="hl-sub-heading">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="hl-body">{{ section.settings.description }}</p>
          {%- endif -%}
          {%- if section.settings.btn_label != blank -%}
            <a href="{{ section.settings.btn_link }}" class="hl-btn hl-btn-white">{{ section.settings.btn_label }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>

  </section>
</div>

{% schema %}
{
  "name": "HL - Video CTA",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Direct URL to an MP4 video. Leave blank to use default."
    },
    {
      "type": "image_picker",
      "id": "wave_image",
      "label": "Wave Image (optional)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Effortless Hydration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Install in seconds"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Convert your insulated water bottle into a hands-free hydration system. Simply connect a drinking tube to a wide mouth water bottle. The perfect element to your Hydro Flask accessories. HydroLid works with insulated bottles from CamelBak, ThermoFlask and more to enjoy ice cold water on the go."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Kit"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "HL - Video CTA"
    }
  ]
}
{% endschema %}
