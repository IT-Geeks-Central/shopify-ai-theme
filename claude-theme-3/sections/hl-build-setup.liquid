{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-product-grid-section">
    <div class="hl-container">

      <div class="hl-section-header">
        <div class="hl-section-header-left">
          {%- if section.settings.eyebrow != blank -%}
            <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="hl-btn hl-btn-accent">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>

      <div class="hl-product-grid">
        {%- assign featured_collection = collections[section.settings.collection] -%}
        {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
          {%- for product in featured_collection.products limit: section.settings.products_count -%}
            <div class="hl-product-card">
              <div class="hl-product-card-image">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}"
                       alt="{{ product.featured_image.alt | default: product.title | escape }}"
                       loading="lazy"
                       width="600"
                       height="600">
                {%- endif -%}
              </div>
              <div class="hl-product-card-info">
                <div class="hl-product-card-stars">★★★★★ <span style="color:#333;margin-left:5px;font-weight:400;">5.0</span></div>
                <h6>{{ product.title }}</h6>
                {%- unless product.price == 0 -%}
                  <p class="hl-product-card-price">
                    {%- if product.price_varies -%}
                      From {{ product.price_min | money }}
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </p>
                {%- endunless -%}
              </div>
              <a href="{{ product.url }}" class="hl-btn hl-btn-accent">Add To Cart</a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- assign placeholder_products = "HydroLid (Lid Only),Field & Fire Kit Bundle...,Base Kit | Hydration Tube...,Magnetic Hydration Tube Clip" | split: "," -%}
          {%- assign placeholder_prices = "$139.00,,$139.00,$139.00" | split: "," -%}
          {%- assign placeholder_images = "https://images.unsplash.com/photo-1602143407151-7111542de6e8?w=600&h=600&fit=crop,https://images.unsplash.com/photo-1553531384-cc64ac80f931?w=600&h=600&fit=crop,https://images.unsplash.com/photo-1523362628745-0c100150b504?w=600&h=600&fit=crop,https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=600&h=600&fit=crop" | split: "," -%}
          {%- for i in (0..3) -%}
            <div class="hl-product-card">
              <div class="hl-product-card-image">
                <img src="{{ placeholder_images[i] }}" alt="{{ placeholder_products[i] }}" loading="lazy" width="600" height="600">
              </div>
              <div class="hl-product-card-info">
                <div class="hl-product-card-stars">★★★★★ <span style="color:#333;margin-left:5px;font-weight:400;">5.0</span></div>
                <h6>{{ placeholder_products[i] }}</h6>
                {%- if placeholder_prices[i] != blank -%}
                  <p class="hl-product-card-price">{{ placeholder_prices[i] }}</p>
                {%- endif -%}
              </div>
              <a href="#" class="hl-btn hl-btn-accent">Add To Cart</a>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "HL - Build Your Setup",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The Gear"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Hydration Setup"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "HL - Build Your Setup"
    }
  ]
}
{% endschema %}
