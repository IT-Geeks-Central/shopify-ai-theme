{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-hero">

    {%- if section.settings.bg_image != blank -%}
      <div class="hl-hero-bg" style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');"></div>
    {%- else -%}
      <div class="hl-hero-bg" style="background-image: url('https://framerusercontent.com/images/35bnAEaEVcpQPJrWCWWekD1J0Q0.png');"></div>
    {%- endif -%}

    <div class="hl-hero-overlay"></div>

    <div class="hl-hero-content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hl-body">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="hl-hero-buttons">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_link }}" class="hl-btn hl-btn-outline-white">{{ section.settings.btn1_label }}</a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link }}" class="hl-btn hl-btn-accent">{{ section.settings.btn2_label }}</a>
        {%- endif -%}
      </div>
    </div>

    <div class="hl-hero-product-card">
      <div class="hl-card-img">
        {%- if section.settings.card_image != blank -%}
          <img src="{{ section.settings.card_image | image_url: width: 600 }}"
               alt="{{ section.settings.card_image.alt | default: section.settings.card_title | escape }}"
               loading="eager"
               width="300"
               height="300">
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1553531384-cc64ac80f931?w=600&h=600&fit=crop"
               alt="{{ section.settings.card_title | escape }}"
               loading="eager"
               width="300"
               height="300">
        {%- endif -%}
      </div>
      {%- if section.settings.card_title != blank -%}
        <h6>{{ section.settings.card_title }}</h6>
      {%- endif -%}
      {%- if section.settings.card_price != blank -%}
        <p class="hl-price">{{ section.settings.card_price }}</p>
      {%- endif -%}
    </div>

    <div class="hl-hero-wave">
      {%- if section.settings.wave_image != blank -%}
        <img src="{{ section.settings.wave_image | image_url: width: 2000 }}" alt="" loading="lazy">
      {%- else -%}
        <img src="https://framerusercontent.com/images/W4MXCALFFY2uUB3RJob5dYyk08.png" alt="" loading="lazy">
      {%- endif -%}
    </div>

  </section>
</div>

{% schema %}
{
  "name": "HL - Hero Banner",
  "tag": "div",
  "class": "hl-hero-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Mission Ready"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ditch the Bladder. Upgrade Your Hydration."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A smarter, lighter, cleaner hydration system built for hikers, backpackers, and wildland firefighters."
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "Upgrade Your Setup"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "header",
      "content": "Floating Product Card"
    },
    {
      "type": "image_picker",
      "id": "card_image",
      "label": "Card Product Image"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Card Product Title",
      "default": "Field & Fire Kit Bundle"
    },
    {
      "type": "text",
      "id": "card_price",
      "label": "Card Product Price",
      "default": "$139.00"
    },
    {
      "type": "header",
      "content": "Wave Divider"
    },
    {
      "type": "image_picker",
      "id": "wave_image",
      "label": "Wave Image (optional, uses default if blank)"
    }
  ],
  "presets": [
    {
      "name": "HL - Hero Banner"
    }
  ]
}
{% endschema %}
