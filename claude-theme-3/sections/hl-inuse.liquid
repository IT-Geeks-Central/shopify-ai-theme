{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}
{{ 'hydrolid-homepage.js' | asset_url | script_tag }}

<div class="hl-section">
  <section class="hl-inuse-section">

    <div class="hl-container-narrow hl-inuse-header">
      <div class="hl-section-header-center">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    </div>

    <div class="hl-insta-ticker">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video_card' -%}
          <div class="hl-insta-card" {{ block.shopify_attributes }}>
            <div class="hl-insta-card-video">
              {%- if block.settings.video_url != blank -%}
                <video src="{{ block.settings.video_url }}" autoplay loop muted playsinline></video>
              {%- else -%}
                <video src="https://framerusercontent.com/assets/MLWPbW1dUQawJLhhun3dBwpgJak.mp4" autoplay loop muted playsinline></video>
              {%- endif -%}
            </div>
            <div class="hl-insta-card-info">
              {%- if block.settings.title != blank -%}
                <h6>{{ block.settings.title }}</h6>
              {%- endif -%}
              {%- if block.settings.price != blank -%}
                <p class="hl-insta-card-price">{{ block.settings.price }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </section>
</div>

{% schema %}
{
  "name": "HL - In Use Ticker",
  "tag": "div",
  "settings": [
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "In Use"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Used in the Wild. Trusted in the Field."
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4)",
          "info": "Direct URL to an MP4 video. Leave blank to use default."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Base Kit Bundle | Insulated Water Bottle Included"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$69.99"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL - In Use Ticker",
      "blocks": [
        {
          "type": "video_card",
          "settings": {
            "title": "Base Kit Bundle | Insulated Water Bottle Included",
            "price": "$69.99"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "title": "Base Kit Bundle | Insulated Water Bottle Included",
            "price": "$69.99"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "title": "Base Kit Bundle | Insulated Water Bottle Included",
            "price": "$69.99"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "title": "Field & Fire Kit Bundle",
            "price": "$149.99"
          }
        }
      ]
    }
  ]
}
{% endschema %}
