{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-trust-section">
    <div class="hl-container">

      <div class="hl-section-header-center" style="margin-bottom:30px;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="hl-trust-badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <div class="hl-trust-badge" {{ block.shopify_attributes }}>
              <svg class="hl-trust-badge-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                {%- case forloop.index -%}
                  {%- when 1 -%}
                    <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8zM5.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM18.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/>
                  {%- when 2 -%}
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
                  {%- when 3 -%}
                    <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                  {%- when 4 -%}
                    <path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/>
                {%- endcase -%}
              </svg>
              <h6>{{ block.settings.title }}</h6>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="hl-final-cta">
        <div class="hl-final-cta-text">
          {%- if section.settings.cta_title != blank -%}
            <h3>{{ section.settings.cta_title }}</h3>
          {%- endif -%}
          {%- if section.settings.cta_description != blank -%}
            <p class="hl-body">{{ section.settings.cta_description }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_btn_label != blank -%}
          <a href="{{ section.settings.cta_btn_link }}" class="hl-btn hl-btn-accent">{{ section.settings.cta_btn_label }}</a>
        {%- endif -%}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "HL - Trust & Guarantee",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The Setup"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built to Perform. Backed by Us."
    },
    {
      "type": "header",
      "content": "Final CTA Bar"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Title",
      "default": "If Something Isn't Right, We'll Make it Right"
    },
    {
      "type": "textarea",
      "id": "cta_description",
      "label": "CTA Description",
      "default": "Hydrolid was built in wildfire conditions where failure isn't an option."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "Upgrade Your Setup"
    },
    {
      "type": "url",
      "id": "cta_btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Badge Title",
          "default": "Trust Badge"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "HL - Trust & Guarantee",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": { "title": "Free Shipping" }
        },
        {
          "type": "trust_badge",
          "settings": { "title": "Field-Tested Quality" }
        },
        {
          "type": "trust_badge",
          "settings": { "title": "Secure Checkout" }
        },
        {
          "type": "trust_badge",
          "settings": { "title": "Customer Support" }
        }
      ]
    }
  ]
}
{% endschema %}
