{{ 'hydrolid-homepage.css' | asset_url | stylesheet_tag }}

<div class="hl-section">
  <section class="hl-blog-section">
    <div class="hl-container">

      <div class="hl-section-header">
        <div class="hl-section-header-left">
          {%- if section.settings.eyebrow != blank -%}
            <p class="hl-sub-heading" style="color: {{ section.settings.eyebrow_color }};">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="hl-btn hl-btn-accent">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>

      <div class="hl-blog-grid">
        {%- assign blog_object = blogs[section.settings.blog] -%}
        {%- if blog_object != blank and blog_object.articles_count > 0 -%}
          {%- for article in blog_object.articles limit: section.settings.posts_count -%}
            <article class="hl-blog-card">
              <div class="hl-blog-card-image">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 700 }}"
                       alt="{{ article.image.alt | default: article.title | escape }}"
                       loading="lazy"
                       width="700"
                       height="525">
                {%- else -%}
                  <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=700&h=500&fit=crop"
                       alt="{{ article.title | escape }}"
                       loading="lazy"
                       width="700"
                       height="525">
                {%- endif -%}
              </div>
              <div class="hl-blog-card-info">
                <h6>{{ article.title }}</h6>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="hl-body">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
                {%- endif -%}
                <a href="{{ article.url }}" class="hl-btn hl-btn-underline">Read More</a>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- assign placeholder_titles = "Fishing with HydroLid - Hydration On...,HydroLid: Essential Tool for Hydration,Camping with HydroLid: A New Level." | split: "," -%}
          {%- assign placeholder_descs = "Fishing is a timeless pastime offering relaxation, excitement, and a connection with nature.,Climbing, whether on natural rock or indoor walls, offers an adrenaline-packed adventure that challenges.,Camping is a beloved outdoor activity that connects people with nature, offering a chance to unwind." | split: "," -%}
          {%- assign placeholder_imgs = "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=700&h=500&fit=crop,https://images.unsplash.com/photo-1522163182402-834f871fd851?w=700&h=500&fit=crop,https://images.unsplash.com/photo-1487730116645-74489c95b41b?w=700&h=500&fit=crop" | split: "," -%}
          {%- for i in (0..2) -%}
            <article class="hl-blog-card">
              <div class="hl-blog-card-image">
                <img src="{{ placeholder_imgs[i] }}" alt="{{ placeholder_titles[i] }}" loading="lazy" width="700" height="525">
              </div>
              <div class="hl-blog-card-info">
                <h6>{{ placeholder_titles[i] }}</h6>
                <p class="hl-body">{{ placeholder_descs[i] }}</p>
                <a href="#" class="hl-btn hl-btn-underline">Read More</a>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "HL - Blog Posts",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "News"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn More About Smarter Hydration."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_count",
      "label": "Number of Posts",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "HL - Blog Posts"
    }
  ]
}
{% endschema %}
