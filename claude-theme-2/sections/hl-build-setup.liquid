        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$139.00"
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show Star Rating",
          "default": true
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "5.0"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL"
        }
