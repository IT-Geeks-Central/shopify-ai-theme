{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-build-setup hl-section">
  <div class="hl-container">

    <!-- Section Header -->
    <div class="hl-section-header">
      <div class="hl-section-header-left">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
            {{ section.settings.eyebrow | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn-accent">
          {{ section.settings.btn_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <!-- Product Grid -->
    <div class="hl-product-grid">
      {%- for block in section.blocks -%}
        <div class="hl-product-card" {{ block.shopify_attributes }}>
          <div class="hl-product-card-image">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                loading="lazy"
                width="300"
                height="300"
              >
            {%- else -%}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;"
              >
            {%- endif -%}
          </div>
          <div class="hl-product-card-info">
            {%- if block.settings.show_stars -%}
              <div class="hl-product-card-stars">★★★★★ <span>{{ block.settings.rating }}</span></div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h6>{{ block.settings.title | escape }}</h6>
            {%- endif -%}
            {%- if block.settings.price != blank -%}
              <p class="hl-product-card-price">{{ block.settings.price | escape }}</p>
            {%- endif -%}
          </div>
          <a href="{{ block.settings.product_url }}" class="hl-btn hl-btn-accent">Add To Cart</a>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HL Build Your Setup",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Gear"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Build Your Hydration Setup"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Fallback Image URL",
          "default": "https://images.unsplash.com/photo-1602143407151-7111542de6e8?w=600&h=600&fit=crop"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "HydroLid (Lid Only)"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$139.00"
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show Star Rating",
          "default": true
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "5.0"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Build Your Setup",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1602143407151-7111542de6e8?w=600&h=600&fit=crop",
            "title": "HydroLid (Lid Only)",
            "price": "$139.00",
            "rating": "5.0"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1553531384-cc64ac80f931?w=600&h=600&fit=crop",
            "title": "Field & Fire Kit Bundle...",
            "price": "",
            "rating": "5.0"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1523362628745-0c100150b504?w=600&h=600&fit=crop",
            "title": "Base Kit | Hydration Tube...",
            "price": "$139.00",
            "rating": "5.0"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=600&h=600&fit=crop",
            "title": "Magnetic Hydration Tube Clip",
            "price": "$139.00",
            "rating": "5.0"
          }
        }
      ]
    }
  ]
}
{% endschema %}
