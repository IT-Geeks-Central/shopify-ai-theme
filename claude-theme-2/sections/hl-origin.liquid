{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-origin-section hl-section">
  <div class="hl-origin-inner">

    <div class="hl-origin-left">
      <!-- Section Header -->
      <div class="hl-section-header-left" style="margin-bottom:30px;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color:var(--hl-white);">
            {{ section.settings.eyebrow | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="color:var(--hl-white);">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>

      <!-- Timeline -->
      <div class="hl-timeline">
        {%- for block in section.blocks -%}
          <div class="hl-timeline-item" {{ block.shopify_attributes }}>
            <div class="hl-timeline-dot"></div>
            <div class="hl-timeline-label">
              {%- if block.settings.label != blank -%}
                <h6>{{ block.settings.label | escape }}</h6>
              {%- endif -%}
            </div>
            <div class="hl-timeline-content">
              {%- if block.settings.title != blank -%}
                <h4>{{ block.settings.title | escape }}</h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="hl-body-14">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Video -->
    <div class="hl-origin-video">
      <video
        src="{{ section.settings.video_url }}"
        autoplay
        loop
        muted
        playsinline
      ></video>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HL Our Origin",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Origin"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Born in Fire. Patented for Performance."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "default": "https://framerusercontent.com/assets/MLWPbW1dUQawJLhhun3dBwpgJak.mp4"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline Milestone",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "The Spark"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100° Wildfire Conditions"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "California front lines, fighting heat exhaustion."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Our Origin",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "label": "The Spark",
            "title": "100° Wildfire Conditions",
            "description": "California front lines, fighting heat exhaustion."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "The Failure",
            "title": "Bladder Water Overheats",
            "description": "Drinking warm plastic water when ice-cold is needed."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "The Solution",
            "title": "Insulated Bottle Workaround",
            "description": "Combining trusted thermal bottles with hydration tubes."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "The Build",
            "title": "Field Tested Prototype",
            "description": "Built by hand, tested in operational environments."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "The Result",
            "title": "Patent Secured",
            "description": "The ultimate hydration system upgrade is born."
          }
        }
      ]
    }
  ]
}
{% endschema %}
