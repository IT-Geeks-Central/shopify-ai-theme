{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-steps-section hl-section">
  <div class="hl-container hl-steps-container">

    <!-- Section Header -->
    <div class="hl-section-header-left" style="margin-bottom:30px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <!-- Steps Row -->
    <div class="hl-steps-row">
      {%- for block in section.blocks -%}
        {%- assign icon_class = 'hl-step-icon--' | append: forloop.index -%}
        <div class="hl-step-card" {{ block.shopify_attributes }}>
          <div class="hl-step-icon {{ icon_class }}">
            {{ block.settings.icon_svg }}
          </div>
          <div class="hl-step-text">
            {%- if block.settings.title != blank -%}
              <h4>{{ block.settings.title | escape }}</h4>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="hl-body-14">{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>

  <!-- Wave Divider -->
  <div class="hl-wave-divider">
    <img
      src="https://framerusercontent.com/images/tjlvTqsztsCOhK7Y20j0jGQfmfU.png"
      alt=""
      loading="lazy"
      aria-hidden="true"
    >
  </div>
</section>

{% schema %}
{
  "name": "HL Three Steps",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Setup"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Three Steps To Smarter Hydration."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M12 5v14M5 12h14\"/></svg>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Attach"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Step Description",
          "default": "Install HydroLid onto your compatible bottle."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Three Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M12 5v14M5 12h14\"/></svg>",
            "title": "Attach",
            "description": "Install HydroLid onto your compatible bottle."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71\"/></svg>",
            "title": "Route",
            "description": "Run the hose through your pack strap."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>",
            "title": "Go",
            "description": "Hydrate without stopping. Without unpacking."
          }
        }
      ]
    }
  ]
}
{% endschema %}
