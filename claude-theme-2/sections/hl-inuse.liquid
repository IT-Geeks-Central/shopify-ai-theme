{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-inuse-section hl-section">

  <div class="hl-container-narrow hl-inuse-header">
    <div class="hl-section-header-center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};font-size:{{ section.settings.eyebrow_size }}px;">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  </div>

  <!-- Scrollable Ticker -->
  <div class="hl-insta-ticker">
    {%- for block in section.blocks -%}
      <div class="hl-insta-card" {{ block.shopify_attributes }}>
        <div class="hl-insta-card-video">
          {%- if block.settings.background_video != blank -%}
            {{ block.settings.background_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
          {%- elsif block.settings.video_url != blank -%}
            <video src="{{ block.settings.video_url }}" autoplay loop muted playsinline></video>
          {%- endif -%}
        </div>
        <div class="hl-insta-card-info">
          {%- if block.settings.title != blank -%}
            <h6 style="font-size:{{ section.settings.subheading_size }}px;">{{ block.settings.title | escape }}</h6>
          {%- endif -%}
          {%- if block.settings.price != blank -%}
            <p class="hl-insta-card-price">{{ block.settings.price | escape }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "HL In Use",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "In Use"
