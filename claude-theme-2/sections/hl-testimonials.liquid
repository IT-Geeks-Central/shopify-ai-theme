{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-testimonials-section hl-section">

  <!-- Header -->
  <div class="hl-testimonials-header hl-container-narrow">
    <div class="hl-section-header-center" style="margin-bottom:10px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
    <div class="hl-stars">
      <span class="hl-star">★</span>
      <span class="hl-star">★</span>
      <span class="hl-star">★</span>
      <span class="hl-star">★</span>
      <span class="hl-star">★</span>
    </div>
    {%- if section.settings.rating_text != blank -%}
      <h6 class="hl-rating-text">{{ section.settings.rating_text | escape }}</h6>
    {%- endif -%}
  </div>

  <!-- Review Cards Ticker -->
  <div class="hl-review-ticker">
    {%- for block in section.blocks -%}
      <div class="hl-review-card" {{ block.shopify_attributes }}>
        <div class="hl-review-card-stars">★★★★★</div>
        {%- if block.settings.review_text != blank -%}
          <p class="hl-review-text">{{ block.settings.review_text | escape }}</p>
        {%- endif -%}
        <div class="hl-review-author">
          <div class="hl-review-author-info">
            {%- if block.settings.author_name != blank -%}
              <h6>{{ block.settings.author_name | escape }}</h6>
            {%- endif -%}
            {%- if block.settings.author_role != blank -%}
              <p class="hl-body-14">{{ block.settings.author_role | escape }}</p>
            {%- endif -%}
          </div>
          <span class="hl-review-badge">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Verified Buyer
          </span>
        </div>
      </div>
    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "HL Testimonials",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The System"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Tested Where Failure Isn't an Option."
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.9/5 Rating"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "text",
          "id": "review_text",
          "label": "Review Text",
          "default": "\"We've had issues with bladders popping in high heat. Hydrolid changed that.\""
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Sgt. Mark Harrison"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "Author Role",
          "default": "US Marine Corps"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "\"We've had issues with bladders popping in high heat. Hydrolid changed that. My Nalgene is now my hydration pack, and it doesn't fail.\"",
            "author_name": "Sgt. Mark Harrison",
            "author_role": "US Marine Corps"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "\"The Hydrolid is standard gear for me now. It's built for the same conditions we are—tough, reliable, and it actually keeps water cool.\"",
            "author_name": "Sarah Miller",
            "author_role": "Wildland Firefighter"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "\"It's the only hydration system that doesn't feel like a cheap plastic toy. The military-grade construction is evident from the first use.\"",
            "author_name": "David Vance",
            "author_role": "Professional Climber"
          }
        }
      ]
    }
  ]
}
{% endschema %}
