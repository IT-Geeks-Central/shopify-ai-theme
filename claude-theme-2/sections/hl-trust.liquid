{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-trust-section hl-section">
  <div class="hl-container">

    <!-- Section Header -->
    <div class="hl-section-header-center" style="margin-bottom:30px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <!-- Trust Badges Grid -->
    <div class="hl-trust-badges">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <div class="hl-trust-badge" {{ block.shopify_attributes }}>
            <div class="hl-trust-badge-icon">
              {{ block.settings.icon_svg }}
            </div>
            {%- if block.settings.title != blank -%}
              <h6>{{ block.settings.title | escape }}</h6>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Final CTA Bar -->
    <div class="hl-final-cta">
      <div class="hl-final-cta-text">
        {%- if section.settings.cta_heading != blank -%}
          <h3>{{ section.settings.cta_heading | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.cta_description != blank -%}
          <p class="hl-body-14">{{ section.settings.cta_description | escape }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_btn_label != blank -%}
        <a href="{{ section.settings.cta_btn_url }}" class="hl-btn hl-btn-accent">
          {{ section.settings.cta_btn_label | escape }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HL Trust Badges",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Setup"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Built to Perform. Backed by Us."
    },
    {
      "type": "header",
      "content": "Final CTA Bar"
    },
    {
