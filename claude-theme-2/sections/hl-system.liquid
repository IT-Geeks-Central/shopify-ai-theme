{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-system-section hl-section">
  <div class="hl-system-inner">

    <!-- Section Header -->
    <div class="hl-section-header-left" style="margin-bottom:30px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="hl-system-content">

      <!-- Left: Product Image -->
      <div class="hl-system-image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: 'HydroLid System' | escape }}"
            loading="lazy"
            width="800"
            height="900"
          >
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1501554728187-ce583db33af7?w=800&h=900&fit=crop"
            alt="HydroLid System"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {%- endif -%}
      </div>

      <!-- Right: Details -->
      <div class="hl-system-details">

        <div class="hl-system-quote">
          {%- if section.settings.quote != blank -%}
            <h3>{{ section.settings.quote | escape }}</h3>
          {%- endif -%}
        </div>

        <div class="hl-features-grid">
          {%- for block in section.blocks -%}
            <div class="hl-feature-item" {{ block.shopify_attributes }}>
              <div class="hl-feature-icon">
                {{ block.settings.icon_svg }}
              </div>
              <p class="hl-body-14">{{ block.settings.text | escape }}</p>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn-accent">
            {{ section.settings.btn_label | escape }}
          </a>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HL The System",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The System"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Not a Lid. A Complete Upgrade System."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Quote / Subheading",
      "default": "HydroLid transforms your bottle into a hands-free hydration system."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "See the System"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Text",
          "default": "Modular hose system"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL The System",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>",
            "text": "Modular hose system"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg>",
            "text": "Quick-access drinking without removing your pack"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71\"/></svg>",
            "text": "Compatible with insulated bottles"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11\"/></svg>",
