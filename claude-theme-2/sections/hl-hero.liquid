{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-hero hl-section">

  <!-- Background Image -->
  <div class="hl-hero-bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1920 }}"
        alt="{{ section.settings.bg_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
      >
    {%- else -%}
      <img
        src="https://framerusercontent.com/images/35bnAEaEVcpQPJrWCWWekD1J0Q0.png"
        alt="HydroLid Hero Background"
        loading="eager"
        style="width:100%;height:100%;object-fit:cover;"
      >
    {%- endif -%}
  </div>

  <!-- Gradient Overlay -->
  <div class="hl-hero-overlay"></div>

  <!-- Hero Text Content -->
  <div class="hl-hero-content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};font-size:{{ section.settings.eyebrow_size }}px;">
        {{ section.settings.eyebrow | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="hl-body-14" style="font-size:{{ section.settings.body_size }}px;">{{ section.settings.description | escape }}</p>
    {%- endif -%}

    <div class="hl-hero-buttons">
      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_url }}" class="hl-btn hl-btn-outline-white" style="font-size:{{ section.settings.button_size }}px;">
          {{ section.settings.btn1_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a href="{{ section.settings.btn2_url }}" class="hl-btn hl-btn-accent" style="font-size:{{ section.settings.button_size }}px;">
          {{ section.settings.btn2_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- Floating Product Card (dynamic via banner_product picker, or static fallback) -->
  <div class="hl-hero-product-card">
    {%- assign hero_product = all_products[section.settings.banner_product] -%}
    {%- unless hero_product == empty -%}
      <a href="{{ hero_product.url }}" class="hl-card-img">
        <img
          src="{{ hero_product.featured_image | image_url: width: 600 }}"
          alt="{{ hero_product.title | escape }}"
          loading="lazy"
          width="280"
          height="280"
        >
      </a>
      <h6 style="font-size:{{ section.settings.subheading_size }}px;">{{ hero_product.title }}</h6>
      <p class="hl-price">{{ hero_product.price | money }}</p>
      {%- form 'product', hero_product -%}
        <input type="hidden" name="id" value="{{ hero_product.selected_or_first_available_variant.id }}">
        <button type="submit" name="add" class="hl-btn hl-btn-accent" style="font-size:{{ section.settings.button_size }}px;">
          Add to Cart
        </button>
      {%- endform -%}
    {%- else -%}
      <div class="hl-card-img">
        {%- if section.settings.card_image != blank -%}
          <img
            src="{{ section.settings.card_image | image_url: width: 600 }}"
            alt="{{ section.settings.card_image.alt | escape }}"
            loading="lazy"
            width="280"
            height="280"
          >
        {%- else -%}
          <img
            src="https://images.unsplash.com/photo-1553531384-cc64ac80f931?w=600&h=600&fit=crop"
            alt="{{ section.settings.card_title | escape }}"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {%- endif -%}
      </div>
      {%- if section.settings.card_title != blank -%}
        <h6 style="font-size:{{ section.settings.subheading_size }}px;">{{ section.settings.card_title | escape }}</h6>
      {%- endif -%}
      {%- if section.settings.card_price != blank -%}
        <p class="hl-price">{{ section.settings.card_price | escape }}</p>
      {%- endif -%}
    {%- endunless -%}
  </div>

  <!-- Bottom Wave Separator -->
  <div class="hl-hero-wave">
    <img
      src="https://framerusercontent.com/images/W4MXCALFFY2uUB3RJob5dYyk08.png"
      alt=""
      loading="lazy"
      aria-hidden="true"
    >
  </div>

</section>

{% schema %}
{
  "name": "HL Hero Banner",
  "tag": "div",
  "class": "hl-hero-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Eyebrow / Subheading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Mission Ready"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Heading & Description"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ditch the Bladder. Upgrade Your Hydration."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "A smarter, lighter, cleaner hydration system built for hikers, backpackers, and wildland firefighters."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "Upgrade Your Setup"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 URL"
    },
    {
      "type": "header",
      "content": "Floating Product Card"
    },
    {
      "type": "image_picker",
      "id": "card_image",
      "label": "Card Image"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Card Product Title",
      "default": "Field & Fire Kit Bundle"
    },
    {
      "type": "text",
      "id": "card_price",
      "label": "Card Price",
      "default": "$139.00"
    },
    {
      "type": "header",
      "content": "Featured Product (Dynamic)"
    },
    {
      "type": "product",
      "id": "banner_product",
      "label": "Featured Product",
      "info": "When set, overrides the static card image/title/price above and shows a native Add to Cart form."
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 80,
      "step": 1,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Font Size",
      "min": 12,
      "max": 48,
      "step": 1,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body Text Font Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow Text Font Size",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 26,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button Text Font Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "HL Hero Banner"
    }
  ]
}
{% endschema %}
