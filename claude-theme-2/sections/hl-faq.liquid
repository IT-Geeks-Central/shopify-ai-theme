{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hl-homepage.js' | asset_url }}" defer></script>

<section class="hl-faq-section hl-section">
  <div class="hl-container">
    <div class="hl-faq-layout">

      <!-- Sidebar -->
      <div class="hl-faq-sidebar">
        <div class="hl-section-header-left">
          {%- if section.settings.eyebrow != blank -%}
            <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
              {{ section.settings.eyebrow | escape }}
            </p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2>{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.description != blank -%}
          <p class="hl-body-14">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn-accent" style="align-self:flex-start;">
            {{ section.settings.btn_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <!-- FAQ List -->
      <div class="hl-faq-list">
        {%- for block in section.blocks -%}
          <div class="hl-faq-item" {{ block.shopify_attributes }}>
            <button class="hl-faq-question" aria-expanded="false">
              {{ block.settings.question | escape }}
            </button>
            <div class="hl-faq-answer" role="region">
              <div class="hl-faq-answer-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "HL FAQ",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Common Questions"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Sidebar Heading",
      "default": "Find Your Answers Fast"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Sidebar Description",
      "default": "Everything you need to know about compatibility, durability, and field use."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Contact Button Label",
      "default": "Contact support"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Contact Button URL"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is HydroLid, and what makes it unique?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>HydroLid offers innovative hydration solutions designed for extreme environments and outdoor recreation. Founded by a wildland firefighter, our products ensure temperature-stable hydration without the need to stop and access your insulated bottle.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is HydroLid, and what makes it unique?",
            "answer": "<p>HydroLid offers innovative hydration solutions designed for extreme environments and outdoor recreation. Founded by a wildland firefighter, our products ensure temperature-stable hydration without the need to stop and access your insulated bottle. From fire & fieldwork to strenuous adventuring, our hands-free hydration kits enhance your experience.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are HydroLid products compatible with other insulated bottles?",
            "answer": "<p>Yes, HydroLid works with wide-mouth Hydro Flask, ThermoFlask and CamelBak insulated bottles, offering a versatile solution to fit various popular bottle brands.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How can HydroLid products be adapted to various hydration capacities and uses?",
            "answer": "<p>HydroLid offers a range of kits that can be customized for different hydration needs, from the HydroLid Base Kit for everyday use to the HydroLid Field & Fire Kit for simultaneous drawing from two bottles. Our products are designed for both professional and recreational use, providing a versatile hydration solution.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How does HydroLid support hydration needs during firefighting operations?",
            "answer": "<p>HydroLid provides firefighters with quick and hands-free hydration access, allowing them to stay focused on the task without having to stop to access their insulated bottles. With temperature-stable hydration, products like the HydroLid Base Kit and HydroLid Field and Fire Kit ensure that firefighters remain refreshed, enhancing stamina and efficiency during firefighting operations.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is HydroLid compatible with the gear typically used by fire departments?",
            "answer": "<p>Yes, HydroLid is designed with versatility in mind and can be used with wide-mouth bottles such as Hydro Flask, ThermoFlask and CamelBak insulated bottles. The lightweight and functional design allows it to integrate seamlessly with standard firefighting equipment.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
