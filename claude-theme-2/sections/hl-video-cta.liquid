{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-video-cta hl-section">

  <!-- Background Video -->
  <div class="hl-video-cta-bg">
    {%- if section.settings.background_video != blank -%}
      {{ section.settings.background_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.video_url != blank -%}
      <video src="{{ section.settings.video_url }}" autoplay loop muted playsinline></video>
    {%- endif -%}
  </div>

  <!-- Brown Gradient Overlay -->
  <div class="hl-video-cta-overlay"></div>

  <!-- Wave Separator -->
  <div class="hl-video-cta-wave">
    <img
      src="https://framerusercontent.com/images/W4MXCALFFY2uUB3RJob5dYyk08.png"
      alt=""
      loading="lazy"
      aria-hidden="true"
    >
  </div>

  <!-- Text Content -->
  <div class="hl-video-cta-content">
    <div class="hl-video-cta-inner">
      <div class="hl-video-cta-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="font-size:{{ section.settings.eyebrow_size }}px;">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="hl-body-14" style="font-size:{{ section.settings.body_size }}px;">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn-white" style="font-size:{{ section.settings.button_size }}px;">
            {{ section.settings.btn_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "HL Video CTA",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL",
      "default": "https://framerusercontent.com/assets/MLWPbW1dUQawJLhhun3dBwpgJak.mp4"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Effortless Hydration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Install in seconds"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Convert your insulated water bottle into a hands-free hydration system. Simply connect a drinking tube to a wide mouth water bottle. The perfect element to your Hydro Flask accessories. HydroLid works with insulated bottles from CamelBak, ThermoFlask and more to enjoy ice cold water on the go."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Kit"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video (Shopify)"
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "HL Video CTA"
    }
  ]
}
{% endschema %}
