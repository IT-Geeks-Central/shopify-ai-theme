            "icon_svg": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><circle cx=\"7\" cy=\"10\" r=\"2\"/><circle cx=\"17\" cy=\"10\" r=\"2\"/><circle cx=\"12\" cy=\"17\" r=\"2\"/></svg>",
            "title": "Heavy when full",
            "description": "Fumbling with zippers and bags slows you down when seconds matter."
          }
        },
        {
          "type": "divider"
        },
        {
          "type": "pain_point",
          "settings": {
