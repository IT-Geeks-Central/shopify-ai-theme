{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-pain-section hl-section">
  <div class="hl-container">

    <div class="hl-section-header-center" style="margin-bottom:30px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="hl-pain-points">
      {%- for block in section.blocks -%}
        {%- if block.type == 'divider' -%}
          <div class="hl-pain-divider" {{ block.shopify_attributes }}></div>
        {%- else -%}
          <div class="hl-pain-point" {{ block.shopify_attributes }}>
            <div class="hl-pain-point-icon">
              {{ block.settings.icon_svg }}
            </div>
            {%- if block.settings.title != blank -%}
              <h4>{{ block.settings.title | escape }}</h4>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="hl-body-14">{{ block.settings.description | escape }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HL Pain Points",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "And in extreme heat? They warm up fast."
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Hydration Bladders Add Bulk. Add Hassle. Add Complexity."
    }
  ],
  "blocks": [
    {
      "type": "pain_point",
      "name": "Pain Point",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><path d=\"M12 3c-4.97 0-9 2.69-9 6v6c0 3.31 4.03 6 9 6s9-2.69 9-6V9c0-3.31-4.03-6-9-6z\"/></svg>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hard to clean"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Standard bladders sit against your body, turning water into tea in minutes."
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "HL Pain Points",
