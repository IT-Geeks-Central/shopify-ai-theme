{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-section" style="overflow:hidden;">
  <div class="hl-collections">
    {%- for block in section.blocks -%}
      <div class="hl-collection-card" {{ block.shopify_attributes }}>
        <div class="hl-collection-card-bg">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
              loading="lazy"
              width="900"
              height="700"
            >
          {%- else -%}
            <img
              src="{{ block.settings.image_url }}"
              alt="{{ block.settings.heading | escape }}"
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;"
            >
          {%- endif -%}
        </div>
        <div class="hl-collection-card-overlay"></div>
        <div class="hl-collection-card-content">
          {%- if block.settings.heading != blank -%}
            <h3>{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="hl-body-14">{{ block.settings.description | escape }}</p>
          {%- endif -%}
          {%- if block.settings.btn_label != blank -%}
            <a href="{{ block.settings.btn_url }}" class="hl-btn hl-btn-white">
              {{ block.settings.btn_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "HL Shop By Category",
  "tag": "div",
  "settings": [],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Fallback Image URL",
          "default": "https://images.unsplash.com/photo-1628260410023-b5f0a26f753c?w=900&h=700&fit=crop"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "For Wildland Firefighters"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Operational hydration that won't fail when the heat hits triple digits. Built for the fire line."
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Shop By Category",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1628260410023-b5f0a26f753c?w=900&h=700&fit=crop",
            "heading": "For Wildland Firefighters",
            "description": "Operational hydration that won't fail when the heat hits triple digits. Built for the fire line.",
            "btn_label": "Shop now"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1551632811-561732d1e306?w=900&h=700&fit=crop",
            "heading": "For Hikers & Backpackers",
            "description": "Ditch the heavy bladder. Upgrade your trail experience with ice-cold water access.",
            "btn_label": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
