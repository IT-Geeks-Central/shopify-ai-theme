{{ 'hl-homepage.css' | asset_url | stylesheet_tag }}

<section class="hl-blog-section hl-section">
  <div class="hl-container">

    <!-- Section Header -->
    <div class="hl-section-header">
      <div class="hl-section-header-left">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hl-sub-heading" style="color:{{ section.settings.eyebrow_color }};font-size:{{ section.settings.eyebrow_size }}px;">
            {{ section.settings.eyebrow | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn-accent" style="font-size:{{ section.settings.button_size }}px;">
          {{ section.settings.btn_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <!-- Blog Grid -->
    <div class="hl-blog-grid">
      {%- for block in section.blocks -%}
        <div class="hl-blog-card" {{ block.shopify_attributes }}>
          <div class="hl-blog-card-image">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 700 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                loading="lazy"
                width="700"
                height="500"
              >
            {%- else -%}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;"
              >
            {%- endif -%}
          </div>
          <div class="hl-blog-card-info">
            {%- if block.settings.title != blank -%}
              <h6 style="font-size:{{ section.settings.subheading_size }}px;">{{ block.settings.title | escape }}</h6>
            {%- endif -%}
            {%- if block.settings.excerpt != blank -%}
              <p class="hl-body-14" style="font-size:{{ section.settings.body_size }}px;">{{ block.settings.excerpt | escape }}</p>
            {%- endif -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="hl-btn-underline">Read More</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HL Blog Posts",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "News"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#1f5a3c"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Learn More About Smarter Hydration."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "blog_card",
      "name": "Blog Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Blog Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Fallback Image URL",
          "default": "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=700&h=500&fit=crop"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Blog Title",
          "default": "Fishing with HydroLid - Hydration On..."
        },
        {
          "type": "text",
          "id": "excerpt",
          "label": "Excerpt",
          "default": "Fishing is a timeless pastime, offering relaxation, excitement, and a connection with nature."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Blog Post URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HL Blog Posts",
      "blocks": [
        {
          "type": "blog_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=700&h=500&fit=crop",
            "title": "Fishing with HydroLid - Hydration On...",
            "excerpt": "Fishing is a timeless pastime, offering relaxation, excitement, and a connection with nature."
          }
        },
        {
          "type": "blog_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=700&h=500&fit=crop",
            "title": "HydroLid: Essential Tool for Hydration",
            "excerpt": "Climbing, whether on natural rock or indoor walls, offers an adrenaline-packed adventure that challenges."
          }
        },
        {
          "type": "blog_card",
          "settings": {
            "image_url": "https://images.unsplash.com/photo-1487730116645-74489c95b41b?w=700&h=500&fit=crop",
            "title": "Camping with HydroLid: A New Level.",
            "excerpt": "Camping is a beloved outdoor activity that connects people with nature, offering a chance to unwind."
          }
        }
      ]
    }
  ]
}
{% endschema %}
