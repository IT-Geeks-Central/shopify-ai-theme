{% comment %} Section: hydrolid-build-setup {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-product-grid-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">

  <div class="hl-container">

    {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.btn_label != blank -%}
      <div class="hl-section-header">
        <div class="hl-section-header-left">
          {%- if section.settings.subheading != blank -%}
            <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn--accent">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.collection != blank -%}
      {%- assign grid_collection = section.settings.collection -%}
      {%- assign max_products = section.settings.max_products -%}

      <div class="hl-product-grid">
        {%- for product in grid_collection.products limit: max_products -%}
          <div class="hl-product-card">
            {%- if product.featured_image != blank -%}
              <div class="hl-product-card__image">
                <a href="{{ product.url }}">
                  {{- product.featured_image | image_url: width: 600 | image_tag: class: 'hl-product-card__img', alt: product.featured_image.alt | escape -}}
                </a>
              </div>
            {%- endif -%}

            <div class="hl-product-card__info">
              {%- if section.settings.show_stars -%}
                <div class="hl-product-card__stars">★★★★★</div>
              {%- endif -%}

              {%- if product.title != blank -%}
                <p class="hl-product-card__title">
                  <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">{{ product.title }}</a>
                </p>
              {%- endif -%}

              <p class="hl-product-card__price">{{ product.price | money }}</p>
            </div>

            {%- if section.settings.show_add_to_cart -%}
              {%- form 'product', product -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="hl-btn hl-btn--accent" name="add">
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              {%- endform -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

    {%- else -%}
      <div class="hl-product-grid">
        {%- for i in (1..4) -%}
          <div class="hl-product-card">
            <div class="hl-product-card__image" style="background: #e8e8e8; aspect-ratio: 1;"></div>
            <div class="hl-product-card__info">
              {%- if section.settings.show_stars -%}
                <div class="hl-product-card__stars">★★★★★</div>
              {%- endif -%}
              <p class="hl-product-card__title">{{ 'onboarding.product_title' | t }}</p>
              <p class="hl-product-card__price">{{ 1999 | money }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "HydroLid Build Setup",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Gear"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Hydration Setup"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum Products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show Star Ratings",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show Add to Cart Button",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "HydroLid Build Setup"
    }
  ]
}
{% endschema %}
