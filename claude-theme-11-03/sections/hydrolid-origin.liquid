{% comment %} Section: hydrolid-origin {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-origin-section" style="background: {{ section.settings.bg_color }}; position: relative; overflow: hidden;">

  {%- if section.settings.bg_image != blank -%}
    <div style="position: absolute; inset: 0; z-index: 0; pointer-events: none; opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};">
      {{- section.settings.bg_image | image_url: width: 1920 | image_tag: style: 'width:100%;height:100%;object-fit:cover;display:block;', alt: '', loading: 'lazy' -}}
    </div>
  {%- endif -%}

  <div class="hl-origin-inner" style="position: relative; z-index: 1;">

    <div class="hl-origin-left">

      {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
        <div class="hl-section-header-left" style="margin-bottom: 32px;">
          {%- if section.settings.subheading != blank -%}
            <p class="hl-sub-heading" style="color: {{ section.settings.subheading_color }}; font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 style="color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="hl-timeline">
        {%- for block in section.blocks -%}
          {%- if block.type == 'timeline_item' -%}
            <div class="hl-timeline-item" {{ block.shopify_attributes }}>
              <div class="hl-timeline-dot"></div>

              {%- if block.settings.label != blank -%}
                <div class="hl-timeline-label">
                  <h6>{{ block.settings.label }}</h6>
                </div>
              {%- endif -%}

              <div class="hl-timeline-content">
                {%- if block.settings.title != blank -%}
                  <h4 style="font-size: {{ block.settings.title_size }}px;">{{ block.settings.title }}</h4>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="hl-body" style="font-size: {{ block.settings.description_size }}px;">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- if section.settings.video != blank -%}
      <div class="hl-origin-video">
        {%- assign vid = section.settings.video -%}
        <video
          autoplay
          loop
          muted
          playsinline
          {% if vid.sources.size > 0 %}
            {%- for source in vid.sources -%}
              {%- if source.mime_type == 'video/mp4' -%}
                src="{{ source.url }}"
              {%- endif -%}
            {%- endfor -%}
          {% endif %}
        >
          {%- for source in vid.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
      </div>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "HydroLid Origin",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Origin"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Born in Fire. Patented for Performance."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a2a3a"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Texture Image"
    },
    {
      "type": "range",
      "id": "bg_image_opacity",
      "label": "Background Image Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. The Spark)",
          "default": "The Spark"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100° Wildfire Conditions"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Title Font Size",
          "min": 12,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 17
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "California front lines, fighting heat exhaustion."
        },
        {
          "type": "range",
          "id": "description_size",
          "label": "Description Font Size",
          "min": 12,
          "max": 18,
          "step": 1,
          "unit": "px",
          "default": 14
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid Origin",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Spark",
            "title": "100° Wildfire Conditions",
            "description": "California front lines, fighting heat exhaustion."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Failure",
            "title": "Bladder Water Overheats",
            "description": "Drinking warm plastic water when ice-cold is needed."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Solution",
            "title": "Insulated Bottle Workaround",
            "description": "Combining trusted thermal bottles with hydration tubes."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Build",
            "title": "Field Tested Prototype",
            "description": "Built by hand, tested in operational environments."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "label": "The Result",
            "title": "Patent Secured",
            "description": "The ultimate hydration system upgrade is born."
          }
        }
      ]
    }
  ]
}
{% endschema %}
