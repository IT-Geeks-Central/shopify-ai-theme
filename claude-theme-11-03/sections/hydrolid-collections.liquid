{% comment %} Section: hydrolid-collections {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-collections">

  {%- for block in section.blocks -%}
    {%- if block.type == 'collection_card' -%}
      <div class="hl-collection-card" {{ block.shopify_attributes }}>

        {%- if block.settings.bg_image != blank -%}
          <div class="hl-collection-card__bg">
            {{- block.settings.bg_image | image_url: width: 1000 | image_tag: class: 'hl-collection-card__bg-img', alt: block.settings.bg_image.alt | escape -}}
          </div>
        {%- endif -%}

        <div
          class="hl-collection-card__overlay"
          style="background: linear-gradient(to top, {{ block.settings.overlay_color }}b8 0%, {{ block.settings.overlay_color }}1a 55%);"
        ></div>

        <div class="hl-collection-card__content">
          {%- if block.settings.heading != blank -%}
            <h3
              style="
                color: {{ block.settings.heading_color }};
                font-size: {{ block.settings.heading_size }}px;
                font-weight: {{ block.settings.heading_weight }};
              "
            >{{ block.settings.heading }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="hl-collection-card__description" style="color: {{ block.settings.description_color }};">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.btn_label != blank -%}
            {%- if block.settings.collection != blank -%}
              {%- assign card_url = block.settings.collection.url -%}
            {%- elsif block.settings.btn_url != blank -%}
              {%- assign card_url = block.settings.btn_url -%}
            {%- else -%}
              {%- assign card_url = '#' -%}
            {%- endif -%}
            <a href="{{ card_url }}" class="hl-btn hl-btn--white">{{ block.settings.btn_label }}</a>
          {%- endif -%}
        </div>

      </div>
    {%- endif -%}
  {%- endfor -%}

</section>

{% schema %}
{
  "name": "HydroLid Collections",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "header",
          "content": "Background"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background Image"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "For Wildland Firefighters"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Heading Font Size",
          "min": 16,
          "max": 48,
          "step": 2,
          "unit": "px",
          "default": 26
        },
        {
          "type": "select",
          "id": "heading_weight",
          "label": "Heading Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "600", "label": "Semi Bold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "700"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Operational hydration that won't fail when the heat hits triple digits. Built for the fire line."
        },
        {
          "type": "color",
          "id": "description_color",
          "label": "Description Color",
          "default": "#e8e8e8"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop now"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to Collection"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Custom Button URL (overrides collection)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "heading": "For Wildland Firefighters",
            "description": "Operational hydration that won't fail when the heat hits triple digits. Built for the fire line.",
            "btn_label": "Shop now"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "heading": "For Hikers & Backpackers",
            "description": "Ditch the heavy bladder. Upgrade your trail experience with ice-cold water access.",
            "btn_label": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
