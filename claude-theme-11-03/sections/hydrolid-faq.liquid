{% comment %} Section: hydrolid-faq {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-faq-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">

  <div class="hl-container">
    <div class="hl-faq-layout">

      <div class="hl-faq-sidebar">
        {%- if section.settings.subheading != blank -%}
          <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="hl-body" style="color: {{ section.settings.description_color }};">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <div>
            <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn--accent">{{ section.settings.btn_label }}</a>
          </div>
        {%- endif -%}
      </div>

      <div class="hl-faq-list" id="hl-faq-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            <div class="hl-faq-item" {{ block.shopify_attributes }}>
              {%- if block.settings.question != blank -%}
                <button class="hl-faq-question" aria-expanded="false">
                  {{ block.settings.question }}
                </button>
              {%- endif -%}
              {%- if block.settings.answer != blank -%}
                <div class="hl-faq-answer" role="region">
                  <div class="hl-faq-answer-inner">{{ block.settings.answer }}</div>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>

</section>

<script>
  (function() {
    var faqList = document.getElementById('hl-faq-{{ section.id }}');
    if (!faqList) return;
    faqList.addEventListener('click', function(e) {
      var btn = e.target.closest('.hl-faq-question');
      if (!btn) return;
      var item = btn.closest('.hl-faq-item');
      if (!item) return;
      var isActive = item.classList.contains('hl-active');
      faqList.querySelectorAll('.hl-faq-item').forEach(function(el) {
        el.classList.remove('hl-active');
        var q = el.querySelector('.hl-faq-question');
        if (q) q.setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item.classList.add('hl-active');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "HydroLid FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Common Questions"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Answers Fast"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Sidebar Description",
      "default": "Everything you need to know about compatibility, durability, and field use."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#555555"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Contact support"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is HydroLid, and what makes it unique?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>HydroLid offers innovative hydration solutions designed for extreme environments and outdoor recreation. Founded by a wildland firefighter, our products ensure temperature-stable hydration without the need to stop and access your insulated bottle.</p>"
        }
      ]
    }
  ],
  "presets": [
