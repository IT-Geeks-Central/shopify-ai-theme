{% comment %} Section: hydrolid-steps {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-steps-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">

  <div class="hl-container">

    {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
      <div class="hl-section-header-left" style="margin-bottom: 36px;">
        {%- if section.settings.subheading != blank -%}
          <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hl-steps-row">
      {%- assign step_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}
          <div class="hl-step-card" {{ block.shopify_attributes }}>

            {%- if block.settings.icon_svg != blank -%}
              <div class="hl-step-icon hl-step-icon--{{ step_count }}" style="background: {{ block.settings.icon_bg }};">
                {{ block.settings.icon_svg }}
              </div>
            {%- endif -%}

            <div class="hl-step-text">
              {%- if block.settings.title != blank -%}
                <h4 style="font-size: {{ block.settings.title_size }}px;">{{ block.settings.title }}</h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="hl-body" style="color: {{ block.settings.description_color }}; font-size: {{ block.settings.description_size }}px;">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

</section>

{% schema %}
{
  "name": "HydroLid Steps",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Setup"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three Steps To Smarter Hydration."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG Code",
          "default": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"#ffffff\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M12 5v14M5 12h14\"/></svg>"
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Icon Background Color",
          "default": "#10497e"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Attach"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Title Font Size",
          "min": 14,
          "max": 32,
          "step": 1,
          "unit": "px",
          "default": 20
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Install HydroLid onto your compatible bottle."
        },
        {
          "type": "range",
          "id": "description_size",
          "label": "Description Font Size",
          "min": 12,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 15
        },
        {
          "type": "color",
          "id": "description_color",
          "label": "Description Color",
          "default": "#555555"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"#ffffff\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M12 5v14M5 12h14\"/></svg>",
            "icon_bg": "#10497e",
            "title": "Attach",
            "description": "Install HydroLid onto your compatible bottle."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"#ffffff\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71\"/></svg>",
            "icon_bg": "#2e6f4e",
            "title": "Route",
            "description": "Run the hose through your pack strap."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"#ffffff\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>",
            "icon_bg": "#1f3d2b",
            "title": "Go",
            "description": "Hydrate without stopping. Without unpacking."
          }
        }
      ]
    }
  ]
}
{% endschema %}
