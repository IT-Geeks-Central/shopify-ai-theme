{% comment %} Section: hydrolid-testimonials {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-testimonials-section" style="background: {{ section.settings.bg_color }};">

  {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.show_stars -%}
    <div class="hl-testimonials-header">
      <div class="hl-section-header-center">
        {%- if section.settings.subheading != blank -%}
          <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.show_stars -%}
        <div class="hl-stars">★★★★★</div>
        {%- if section.settings.rating_text != blank -%}
          <p class="hl-rating-text">{{ section.settings.rating_text }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="hl-review-ticker">
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        <div class="hl-review-card" {{ block.shopify_attributes }}>

          {%- if block.settings.show_stars -%}
            <div class="hl-review-card__stars">★★★★★</div>
          {%- endif -%}

          {%- if block.settings.review_text != blank -%}
            <p class="hl-review-card__text" style="font-size: {{ block.settings.text_size }}px;">"{{ block.settings.review_text }}"</p>
          {%- endif -%}

          <div class="hl-review-card__author">
            <div>
              {%- if block.settings.author_name != blank -%}
                <p class="hl-review-card__author-name">{{ block.settings.author_name }}</p>
              {%- endif -%}
              {%- if block.settings.author_role != blank -%}
                <p class="hl-review-card__author-role">{{ block.settings.author_role }}</p>
              {%- endif -%}
            </div>
            {%- if block.settings.show_badge -%}
              <span class="hl-review-badge">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {{ block.settings.badge_label | default: 'Verified Buyer' }}
              </span>
            {%- endif -%}
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "HydroLid Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The System"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tested Where Failure Isn't an Option."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show Overall Star Rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.9/5 Rating"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show Stars",
          "default": true
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "We've had issues with bladders popping in high heat. Hydrolid changed that. My Nalgene is now my hydration pack, and it doesn't fail."
        },
        {
          "type": "range",
          "id": "text_size",
          "label": "Review Text Size",
          "min": 12,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 15
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Sgt. Mark Harrison"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "Author Role / Title",
          "default": "US Marine Corps"
        },
        {
          "type": "checkbox",
          "id": "show_badge",
          "label": "Show Verified Badge",
          "default": true
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "We've had issues with bladders popping in high heat. Hydrolid changed that. My Nalgene is now my hydration pack, and it doesn't fail.",
            "author_name": "Sgt. Mark Harrison",
            "author_role": "US Marine Corps"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "The Hydrolid is standard gear for me now. It's built for the same conditions we are—tough, reliable, and it actually keeps water cool.",
            "author_name": "Sarah Miller",
            "author_role": "Wildland Firefighter"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "It's the only hydration system that doesn't feel like a cheap plastic toy. The military-grade construction is evident from the first use.",
            "author_name": "David Vance",
            "author_role": "Professional Climber"
          }
        }
      ]
    }
  ]
}
{% endschema %}
