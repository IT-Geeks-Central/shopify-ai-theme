{% comment %} Section: hydrolid-trust {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-trust-section" style="padding-top: {{ section.settings.padding_top }}px; background: {{ section.settings.bg_color }};">

  <div class="hl-container">

    {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
      <div class="hl-section-header-center" style="margin-bottom: 32px;">
        {%- if section.settings.subheading != blank -%}
          <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hl-trust-badges">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <div class="hl-trust-badge" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_svg != blank -%}
              <div class="hl-trust-badge__icon">
                {{ block.settings.icon_svg }}
              </div>
            {%- endif -%}
            {%- if block.settings.label != blank -%}
              <p class="hl-trust-badge__label" style="font-size: {{ block.settings.label_size }}px;">{{ block.settings.label }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_heading != blank or section.settings.cta_description != blank or section.settings.cta_btn_label != blank -%}
      <div class="hl-final-cta">
        <div class="hl-final-cta__text">
          {%- if section.settings.cta_heading != blank -%}
            <h3 style="font-size: {{ section.settings.cta_heading_size }}px;">{{ section.settings.cta_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.cta_description != blank -%}
            <p class="hl-body" style="color: {{ section.settings.cta_description_color }};">{{ section.settings.cta_description }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_btn_label != blank -%}
          <a href="{{ section.settings.cta_btn_url }}" class="hl-btn hl-btn--accent">{{ section.settings.cta_btn_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "HydroLid Trust Badges",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Setup"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built to Perform. Backed by Us."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Final CTA Bar"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "If Something Isn't Right, We'll Make it Right"
    },
    {
      "type": "range",
      "id": "cta_heading_size",
      "label": "CTA Heading Font Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "textarea",
      "id": "cta_description",
      "label": "CTA Description",
      "default": "Hydrolid was built in wildfire conditions where failure isn't an option."
    },
    {
      "type": "color",
      "id": "cta_description_color",
      "label": "CTA Description Color",
      "default": "#555555"
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "Upgrade Your Setup"
    },
    {
      "type": "url",
      "id": "cta_btn_url",
      "label": "CTA Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG Code",
          "default": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\" width=\"32\" height=\"32\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge Label",
          "default": "Field-Tested Quality"
        },
        {
          "type": "range",
          "id": "label_size",
          "label": "Label Font Size",
          "min": 12,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 15
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon_svg": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\" width=\"32\" height=\"32\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"2\"/><path d=\"M16 8h4l3 3v5h-7V8zM5.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM18.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5z\"/></svg>",
            "label": "Free Shipping"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_svg": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\" width=\"32\" height=\"32\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>",
            "label": "Field-Tested Quality"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_svg": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\" width=\"32\" height=\"32\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>",
            "label": "Secure Checkout"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_svg": "<svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\" width=\"32\" height=\"32\"><path d=\"M3 18v-6a9 9 0 0118 0v6\"/><path d=\"M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z\"/></svg>",
            "label": "Customer Support"
          }
        }
      ]
    }
  ]
}
{% endschema %}
