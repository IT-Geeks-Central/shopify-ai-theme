{% comment %} Section: hydrolid-system {% endcomment %}
{{ 'hydrolid-custom.css' | asset_url | stylesheet_tag }}

<section id="shopify-section-{{ section.id }}" class="hl-system-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">

  <div class="hl-system-inner">

    {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
      <div class="hl-section-header-left" style="margin-bottom: 32px;">
        {%- if section.settings.subheading != blank -%}
          <p class="hl-sub-heading" style="font-size: {{ section.settings.subheading_size }}px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: {{ section.settings.heading_size }}px; font-weight: {{ section.settings.heading_weight }}; letter-spacing: -0.8px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hl-system-content">

      {%- if section.settings.image != blank -%}
        <div class="hl-system-image" style="height: {{ section.settings.image_height }}px;">
          {{- section.settings.image | image_url: width: 900 | image_tag: class: 'hl-system-image-tag', alt: section.settings.image.alt | escape -}}
        </div>
      {%- endif -%}

      <div class="hl-system-details">

        {%- if section.settings.quote != blank -%}
          <div class="hl-system-quote" style="border-left-color: {{ section.settings.quote_border_color }};">
            <h3 style="font-size: {{ section.settings.quote_size }}px; color: {{ section.settings.quote_color }};">{{ section.settings.quote }}</h3>
          </div>
        {%- endif -%}

        <div class="hl-features-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="hl-feature-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_svg != blank -%}
                  <div class="hl-feature-icon" style="color: {{ block.settings.icon_color }};">
                    {{ block.settings.icon_svg }}
                  </div>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="hl-body" style="font-size: {{ block.settings.text_size }}px;">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.btn_label != blank -%}
          <div>
            <a href="{{ section.settings.btn_url }}" class="hl-btn hl-btn--accent">{{ section.settings.btn_label }}</a>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "HydroLid System",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The System"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not a Lid. A Complete Upgrade System."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image Height",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 460
    },
    {
      "type": "header",
      "content": "Quote Block"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote Text",
      "default": "HydroLid transforms your bottle into a hands-free hydration system."
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote Font Size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Quote Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "quote_border_color",
      "label": "Quote Border Color",
      "default": "#10497e"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "See the System"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2f6f4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG Code",
          "default": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#10497e"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Description",
          "default": "Modular hose system"
        },
        {
          "type": "range",
          "id": "text_size",
          "label": "Text Font Size",
          "min": 12,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 15
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HydroLid System",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>",
            "text": "Modular hose system"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg>",
            "text": "Quick-access drinking without removing your pack"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71\"/></svg>",
            "text": "Compatible with insulated bottles"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_svg": "<svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path d=\"M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11\"/></svg>",
            "text": "Built for rugged use"
          }
        }
      ]
    }
  ]
}
{% endschema %}
