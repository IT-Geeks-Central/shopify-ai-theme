    "pain_points_hydrolid": {
      "type": "custom-multicolumn",
      "blocks": {
        "pain_1": { "type": "column", "settings": { "heading": "Hard to clean", "body": "Standard bladders sit against your body, turning water into tea in minutes." } },
        "pain_2": { "type": "column", "settings": { "heading": "Heavy when full", "body": "Fumbling with zippers and bags slows you down when seconds matter." } },
        "pain_3": { "type": "column", "settings": { "heading": "Slows access", "body": "Poor hydration leads to fatigue. Hydrolid keeps you at peak operational capacity." } }
      },
      "block_order": ["pain_1", "pain_2", "pain_3"],
      "settings": {
        "eyebrow_text": "And in extreme heat? They warm up fast.",
        "heading": "Hydration Bladders Add Bulk. Add Hassle. Add Complexity.",
