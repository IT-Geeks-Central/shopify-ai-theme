    "testimonials_hydrolid": {
      "type": "custom-testimonials",
      "blocks": {
        "rev_1": { "type": "review", "settings": { "quote": "\"We've had issues with bladders popping in high heat. Hydrolid changed that. My Nalgene is now my hydration pack, and it doesn't fail.\"", "reviewer_name": "Sgt. Mark Harrison", "reviewer_role": "US Marine Corps" } },
        "rev_2": { "type": "review", "settings": { "quote": "\"The Hydrolid is standard gear for me now. It's built for the same conditions we are—tough, reliable, and it actually keeps water cool.\"", "reviewer_name": "Sarah Miller", "reviewer_role": "Wildland Firefighter" } },
        "rev_3": { "type": "review", "settings": { "quote": "\"It's the only hydration system that doesn't feel like a cheap plastic toy. The military-grade construction is evident from the first use.\"", "reviewer_name": "David Vance", "reviewer_role": "Professional Climber" } }
      },
      "block_order": ["rev_1", "rev_2", "rev_3"],
      "settings": {
        "eyebrow_text": "The System",
        "heading": "Tested Where Failure Isn't an Option.",
        "rating_badge": "4.9/5 Rating",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 80
      }
    },
