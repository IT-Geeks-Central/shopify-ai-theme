    "faq_hydrolid": {
      "type": "custom-faq",
      "blocks": {
        "faq_1": { "type": "item", "settings": { "question": "What is HydroLid, and what makes it unique?", "answer": "HydroLid offers innovative hydration solutions designed for extreme environments and outdoor recreation. Founded by a wildland firefighter, our products ensure temperature-stable hydration without the need to stop and access your insulated bottle." } },
        "faq_2": { "type": "item", "settings": { "question": "Are HydroLid products compatible with other insulated bottles?", "answer": "Yes, HydroLid works with wide-mouth Hydro Flask, ThermoFlask and CamelBak insulated bottles, offering a versatile solution to fit various popular bottle brands." } },
        "faq_3": { "type": "item", "settings": { "question": "How can HydroLid products be adapted to various hydration capacities and uses?", "answer": "HydroLid offers a range of kits that can be customized for different hydration needs, from the HydroLid Base Kit for everyday use to the HydroLid Field & Fire Kit for simultaneous drawing from two bottles." } },
        "faq_4": { "type": "item", "settings": { "question": "How does HydroLid support hydration needs during firefighting operations?", "answer": "HydroLid provides firefighters with quick and hands-free hydration access, allowing them to stay focused on the task without having to stop to access their insulated bottles." } },
        "faq_5": { "type": "item", "settings": { "question": "Is HydroLid compatible with the gear typically used by fire departments?", "answer": "Yes, HydroLid is designed with versatility in mind and can be used with wide-mouth bottles such as Hydro Flask, ThermoFlask and CamelBak insulated bottles." } }
      },
      "block_order": ["faq_1", "faq_2", "faq_3", "faq_4", "faq_5"],
      "settings": {
        "eyebrow_text": "Common Questions",
        "heading": "Find Your Answers Fast",
        "subtext": "Everything you need to know about compatibility, durability, and field use.",
        "contact_link_label": "Contact support",
        "color_scheme": "scheme-1",
        "padding_top": 80,
