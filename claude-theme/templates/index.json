    "video_cta_hydrolid": {
      "type": "custom-image-with-text",
      "settings": {
        "eyebrow_text": "Effortless Hydration",
        "heading": "Install in seconds",
        "media_type": "video",
        "media_position": "right",
        "content_body": "Convert your insulated water bottle into a hands-free hydration system. Simply connect a drinking tube to a wide mouth water bottle. HydroLid works with insulated bottles from CamelBak, ThermoFlask and more to enjoy ice cold water on the go.",
