{{ 'section-custom-origin-timeline.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .custom-ot-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<section
  class="custom-ot-section color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>

  {%- comment -%}Background image{%- endcomment -%}
  <div class="custom-ot__bg" aria-hidden="true">
    {%- if section.settings.background_image != blank -%}
      {%- assign bg_alt = section.settings.background_image.alt | default: '' | escape -%}
      {{
        section.settings.background_image
        | image_url: width: 2000
        | image_tag:
          loading: 'lazy',
          alt: bg_alt,
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    {%- endif -%}
    <div class="custom-ot__bg-overlay"></div>
  </div>

  <div class="custom-ot__inner">

    {%- comment -%}Left: header + timeline{%- endcomment -%}
    <div class="custom-ot__left">
      {%- if section.settings.eyebrow != blank -%}
        <span class="custom-ot__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="custom-ot__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="custom-ot__timeline">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="custom-ot__item" {{ block.shopify_attributes }}>
              <div class="custom-ot__dot" aria-hidden="true"></div>
              <div class="custom-ot__item-label">
                {%- if block.settings.step_label != blank -%}
                  <p class="custom-ot__label-text">{{ block.settings.step_label | escape }}</p>
                {%- endif -%}
              </div>
              <div class="custom-ot__item-content">
                {%- if block.settings.step_title != blank -%}
                  <h4 class="custom-ot__item-title">{{ block.settings.step_title | escape }}</h4>
                {%- endif -%}
                {%- if block.settings.step_description != blank -%}
                  <p class="custom-ot__item-body">{{ block.settings.step_description }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%}Right: video{%- endcomment -%}
    {%- if section.settings.video_url != blank -%}
      <div class="custom-ot__video-wrap">
        {%- assign poster_url = '' -%}
        {%- if section.settings.video_poster != blank -%}
          {%- assign poster_url = section.settings.video_poster | image_url: width: 700 -%}
        {%- endif -%}
        <video
          autoplay
          muted
          loop
          playsinline
          width="100%"
          {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}
          style="object-fit:cover;width:100%;height:100%;"
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Origin Timeline",
  "tag": "section",
  "class": "custom-ot-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Origin"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Born in Fire. Patented for Performance."
    },
    {
      "type": "header",
      "content": "Video (right column)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (mp4)"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video poster image"
    },
    {
      "type": "header",
      "content": "Color & Spacing"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Timeline Step",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Step label (e.g. The Spark)",
          "default": "The Spark"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step title",
          "default": "100° Wildfire Conditions"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step description",
          "default": "California front lines, fighting heat exhaustion."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Origin Timeline",
      "category": "HydroLid",
      "blocks": {
        "step_1": { "type": "step", "settings": { "step_label": "The Spark", "step_title": "100° Wildfire Conditions", "step_description": "California front lines, fighting heat exhaustion." } },
        "step_2": { "type": "step", "settings": { "step_label": "The Failure", "step_title": "Bladder Water Overheats", "step_description": "Drinking warm plastic water when ice-cold is needed." } },
        "step_3": { "type": "step", "settings": { "step_label": "The Solution", "step_title": "Insulated Bottle Workaround", "step_description": "Combining trusted thermal bottles with hydration tubes." } },
        "step_4": { "type": "step", "settings": { "step_label": "The Build", "step_title": "Field Tested Prototype", "step_description": "Built by hand, tested in operational environments." } },
        "step_5": { "type": "step", "settings": { "step_label": "The Result", "step_title": "Patent Secured", "step_description": "The ultimate hydration system upgrade is born." } }
      },
      "block_order": ["step_1", "step_2", "step_3", "step_4", "step_5"]
    }
  ]
}
{% endschema %}
