{{ 'section-custom-multicolumn-hydrolid.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .custom-mc-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{%- liquid
  assign layout_style = section.settings.layout_style | default: 'grid-3'
  assign header_align = section.settings.header_alignment | default: 'left'
  assign col_count = section.blocks | where: 'type', 'column' | size
  assign show_dividers = section.settings.show_column_dividers
-%}

<section
  class="custom-mc-section color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="custom-mc__inner">

    {%- comment -%}Section header{%- endcomment -%}
    {%- if section.settings.header_cta_label != blank -%}
      {%- assign show_header_cta = true -%}
    {%- else -%}
      {%- assign show_header_cta = false -%}
    {%- endif -%}
    {%- if section.settings.eyebrow_text != blank or section.settings.heading != blank -%}
      <div class="custom-mc__header{% if show_header_cta %} custom-mc__header--space-between{% elsif header_align == 'center' %} custom-mc__header--center{% else %} custom-mc__header--left{% endif %}">
        <div class="custom-mc__header-left">
          {%- if section.settings.eyebrow_text != blank -%}
            <span class="custom-mc__eyebrow">{{ section.settings.eyebrow_text | escape }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="custom-mc__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if show_header_cta -%}
          <a href="{{ section.settings.header_cta_url | default: '#' }}" class="custom-mc__header-cta">
            {{ section.settings.header_cta_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%}Columns{%- endcomment -%}
    {%- if layout_style == 'pain-points' -%}
      <div class="custom-mc__columns custom-mc__columns--pain">
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            <div class="custom-mc__column" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_svg != blank -%}
                <div class="custom-mc__col-icon">{{ block.settings.icon_svg }}</div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="custom-mc__col-heading">{{ block.settings.heading | escape }}</h4>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <p class="custom-mc__col-body">{{ block.settings.body }}</p>
              {%- endif -%}
            </div>
            {%- unless forloop.last -%}
              <div class="custom-mc__divider" aria-hidden="true"></div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- elsif layout_style == 'steps' -%}
      <div class="custom-mc__columns custom-mc__columns--3{% if show_dividers %} custom-mc__columns--dividers{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            {%- assign step_num = forloop.index -%}
            <div class="custom-mc__column custom-mc__column--no-bg" {{ block.shopify_attributes }}>
              <div class="custom-mc__step-icon custom-mc__step-icon--{{ step_num }}">
                {%- if block.settings.icon_svg != blank -%}
                  {{ block.settings.icon_svg }}
                {%- else -%}
                  <span style="font-family:var(--font-heading--family);font-weight:700;font-size:24px;">{{ step_num }}</span>
                {%- endif -%}
              </div>
              <div style="display:flex;flex-direction:column;gap:12px;align-items:center;">
                {%- if block.settings.heading != blank -%}
                  <h4 class="custom-mc__col-heading">{{ block.settings.heading | escape }}</h4>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <p class="custom-mc__col-body">{{ block.settings.body }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- assign grid_cols = '3' -%}
      {%- if layout_style == 'grid-4' -%}{%- assign grid_cols = '4' -%}{%- endif -%}
      <div class="custom-mc__columns custom-mc__columns--{{ grid_cols }}{% if show_dividers %} custom-mc__columns--dividers{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            <div class="custom-mc__column" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_svg != blank -%}
                <div class="custom-mc__col-icon">{{ block.settings.icon_svg }}</div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="custom-mc__col-heading">{{ block.settings.heading | escape }}</h4>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <p class="custom-mc__col-body">{{ block.settings.body }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}Optional bottom CTA bar (trust-badges footer){%- endcomment -%}
    {%- if section.settings.footer_cta_heading != blank -%}
      <div class="custom-mc__footer-cta">
        <div class="custom-mc__footer-cta-text">
          <h3 class="custom-mc__footer-cta-heading">{{ section.settings.footer_cta_heading }}</h3>
          {%- if section.settings.footer_cta_body != blank -%}
            <p class="custom-mc__footer-cta-body">{{ section.settings.footer_cta_body }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.footer_cta_btn_label != blank -%}
          <a href="{{ section.settings.footer_cta_btn_url | default: '#' }}" class="custom-mc__footer-cta-btn">
            {{ section.settings.footer_cta_btn_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Multicolumn",
  "tag": "section",
  "class": "custom-mc-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "header_cta_label",
      "label": "Header CTA label (e.g. View All)"
    },
    {
      "type": "url",
      "id": "header_cta_url",
      "label": "Header CTA URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "grid-3", "label": "3-column grid" },
        { "value": "grid-4", "label": "4-column grid" },
        { "value": "pain-points", "label": "Pain Points (flex with dividers)" },
        { "value": "steps", "label": "Steps (numbered circles)" }
      ],
      "default": "grid-3"
    },
    {
      "type": "checkbox",
      "id": "show_column_dividers",
      "label": "Show dividers between columns",
      "default": false
    },
    {
      "type": "header",
      "content": "Bottom CTA Bar (optional)"
    },
    {
      "type": "textarea",
      "id": "footer_cta_heading",
      "label": "Footer CTA heading"
    },
    {
      "type": "textarea",
      "id": "footer_cta_body",
      "label": "Footer CTA body text"
    },
    {
      "type": "text",
      "id": "footer_cta_btn_label",
      "label": "Footer CTA button label"
    },
    {
      "type": "url",
      "id": "footer_cta_btn_url",
      "label": "Footer CTA button URL"
    },
    {
      "type": "header",
      "content": "Color & Spacing"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "default": "Description text goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pain Points",
      "category": "HydroLid",
      "settings": {
        "layout_style": "pain-points",
        "eyebrow_text": "And in extreme heat? They warm up fast.",
        "heading": "Hydration Bladders Add Bulk. Add Hassle. Add Complexity.",
        "header_alignment": "center",
        "color_scheme": "scheme-1"
      },
      "blocks": {
        "col_1": {
          "type": "column",
          "settings": {
            "heading": "Hard to clean",
            "body": "Standard bladders sit against your body, turning water into tea in minutes."
          }
        },
        "col_2": {
          "type": "column",
          "settings": {
            "heading": "Heavy when full",
            "body": "Fumbling with zippers and bags slows you down when seconds matter."
          }
        },
        "col_3": {
          "type": "column",
          "settings": {
            "heading": "Slows access",
            "body": "Poor hydration leads to fatigue. Hydrolid keeps you at peak operational capacity."
          }
        }
      },
      "block_order": ["col_1", "col_2", "col_3"]
    }
  ]
}
{% endschema %}
